@model AMachadoAssignment003.Models.UserModel

@{
    ViewData["Title"] = "EditSalary";
}

<h1>Editing Salary</h1>

<h4>UserModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="EditSalary">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group" hidden>
                <label asp-for="FirstName" class="control-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="form-group" hidden>
                <label asp-for="LastName" class="control-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="form-group" hidden>
                <label asp-for="Department" class="control-label"></label>
                <input asp-for="Department" class="form-control" id="Department" />
                <span asp-validation-for="Department" class="text-danger"></span>
            </div>
            <div class="form-group" hidden>
                <label asp-for="Position" class="control-label"></label>
                <input asp-for="Position" class="form-control" id="Position" />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>
            <div class="form-group" hidden>
                <label asp-for="YearsOfExperience" class="control-label"></label>
                <input asp-for="YearsOfExperience" class="form-control" />
                <span asp-validation-for="YearsOfExperience" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Salary" class="control-label"></label>
                <input asp-for="Salary" class="form-control" />
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    @if (Model.Department == "IT")
    {
        <a asp-action="ITList">Back to List</a>
    }
    @if (Model.Department == "Business")
    {
        <a asp-action="BusinessList">Back to List</a>
    }
</div>

